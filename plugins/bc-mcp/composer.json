{
    "name": "baserproject/bc-mcp",
    "description": "BcMcp plugin for baserCMS",
    "homepage": "https://basercms.net",
    "type": "cakephp-plugin",
    "license": "MIT",
    "vendor-dir": "../../vendor",
    "require": {
        "php": "^8.1",
        "ext-openssl": "*",
        "league/oauth2-server": "^8.5",
        "php-mcp/server": "^3.3",
        "nyholm/psr7": "^1.8",
        "symfony/psr-http-message-bridge": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "BcMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BcMcp\\Test\\": "tests/"
        }
    }
}
